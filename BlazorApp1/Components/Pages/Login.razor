@page "/login"
@rendermode InteractiveServer

@using BlazorApp1.Services
@using Microsoft.AspNetCore.Components.Forms

@inject AuthService authService
@inject NavigationManager nav

<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
        color: #1f1f1f;
    }

    .login-card {
        width: 420px;
        background: rgba(255,255,255,.95);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,.1);
    }

    .login-title {
        text-align: center;
        font-size: 34px;
        font-weight: 700;
        margin-bottom: 10px;
        color: #1f1f1f;
    }

    .login-subtitle {
        text-align: center;
        color: #666;
        margin-bottom: 30px;
    }

    .login-input {
        width: 100%;
        padding: 16px;
        margin-bottom: 16px;
        border: 1px solid #ddd;
        border-radius: 14px;
        background: #f9f9f9;
        color: #1f1f1f;
        font-size: 15px;
        outline: none;
        box-sizing: border-box;
        transition: .2s;
    }

        .login-input:focus {
            background: white;
            border-color: #7b4dff;
            box-shadow: 0 0 0 2px rgba(123, 77, 255, 0.1);
        }

    .login-btn {
        width: 100%;
        padding: 16px;
        border: none;
        border-radius: 14px;
        background: #7b4dff;
        color: white;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: .2s;
        margin-top: 10px;
    }

        .login-btn:hover {
            transform: translateY(-2px);
            opacity: .95;
        }

    .error-box {
        margin-top: 18px;
        background: rgba(220, 20, 60, .1);
        border: 1px solid #dc143c;
        color: #dc143c;
        padding: 14px;
        border-radius: 12px;
        text-align: center;
    }
</style>

<div class="login-page">

    <div class="login-card">

        <div class="login-title">
            Вход
        </div>

        <div class="login-subtitle">
            Авторизация в системе задач
        </div>

        <EditForm Model="authService"
                  OnValidSubmit="HandleLogin">

            <DataAnnotationsValidator />

            <InputText @bind-Value="authService.Email"
                       class="login-input"
                       placeholder="Email" />

            <InputText @bind-Value="authService.Password"
                       type="password"
                       class="login-input"
                       placeholder="Пароль" />

            <button type="submit"
                    class="login-btn">

                Войти

            </button>

        </EditForm>

        @if (isError)
        {
            <div class="error-box">
                Неверный логин или пароль
            </div>
        }

    </div>

</div>

@code {
    bool isError = false;

    async Task HandleLogin()
    {
        isError = false;

        var user = await authService.CheckUser();

        if (user != null)
        {
            await authService.SetUserAsync(user);

            nav.NavigateTo("/tasks", true);
        }
        else
        {
            isError = true;
        }
    }
}