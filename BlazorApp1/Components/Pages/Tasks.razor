    }

    
    

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            currentUser = await authService.GetUserAsync();

            if (currentUser == null)
            {
                nav.NavigateTo("/login", true);
                return;
            }

            departments =
                await _context.Departments.ToListAsync();

            statuses =
                await _context.WorkTaskStatuses.ToListAsync();

            priorities =
                await _context.WorkTaskPriorities.ToListAsync();

            users =
                await _context.Users.ToListAsync();

            allTasks =
                await _context.WorkTasks.ToListAsync();

            taskFiles =
                await _context.TaskFiles.ToListAsync();

            comments =
                await _context.TaskComments.ToListAsync();

            selectedDepartmentId =
                currentUser.Departments_idD;

            tasks = allTasks;

            isLoaded = true;

            StateHasChanged();
        }
    }
    
    void SelectDepartment(int departmentId)
    {
        selectedDepartmentId = departmentId;

        tasks = allTasks
            .Where(t => t.Departments_idD == selectedDepartmentId)
            .ToList();
    }
    async Task OpenTask(WorkTask task)
    {
        selectedTask = task;

        comments = await _context.TaskComments
            .Where(c => c.Tasks_idT == task.idT)
            .OrderBy(c => c.CommentTC)
            .ToListAsync();
    }

    void CloseTask()
    {
        selectedTask = null;
    }
        
    async Task AddTask()
    {
        if (currentUser?.Role != "Admin"
    && currentUser?.Role != "Manager")
        {
            return;
        }
        if (currentUser == null)
            return;

        var assignee = await _context.Users
            .FirstOrDefaultAsync(u => u.idU == newTask.AssigneeId);

        if (assignee == null)
            return;

        newTask.Departments_idD =
    selectedDepartmentForTask;

        newTask.CreatedById = currentUser.idU;

        newTask.CreatedAtT = DateTime.Now;

        if (newTask.TaskStatus_idTS == 0)
            newTask.TaskStatus_idTS = statuses.First().idTS;

        if (newTask.TaskPriority_idTP == 0)
            newTask.TaskPriority_idTP = priorities.First().idTP;

        _context.WorkTasks.Add(newTask);

        await _context.SaveChangesAsync();

        if (selectedFile != null)
        {
            var uploadsFolder = Path.Combine(
                env.WebRootPath,
                "uploads"
            );

            if (!Directory.Exists(uploadsFolder))
            {
                Directory.CreateDirectory(uploadsFolder);
            }

            var uniqueFileName =
                $"{Guid.NewGuid()}_{selectedFile.Name}";

            var filePath = Path.Combine(
                uploadsFolder,
                uniqueFileName
            );

            await using var stream =
                new FileStream(filePath, FileMode.Create);

            await selectedFile
                .OpenReadStream(20 * 1024 * 1024)
                .CopyToAsync(stream);

            var taskFile = new TaskFile
                {
                    FileName = selectedFile.Name,
                    _FilePath = $"/uploads/{uniqueFileName}",
                    UploadedAtTF = DateTime.Now,
                    Tasks_idT = newTask.idT
                };

            _context.TaskFiles.Add(taskFile);

            await _context.SaveChangesAsync();
        }

        allTasks = await _context.WorkTasks.ToListAsync();

        tasks = allTasks
            .Where(t => t.Departments_idD == selectedDepartmentId)
            .ToList();

        newTask = new WorkTask();

        selectedFile = null;

        showCreateModal = false;

        StateHasChanged();
    }

    async Task ChangeStatus(WorkTask task, string? statusId)
    {
        if (int.TryParse(statusId, out int newStatus))
        {
            task.TaskStatus_idTS = newStatus;
            
            task.UpdatedAtT = DateTime.Now;

            _context.WorkTasks.Update(task);

            await _context.SaveChangesAsync();

            allTasks = await _context.WorkTasks.ToListAsync();

            tasks = allTasks
                .Where(t => t.Departments_idD == selectedDepartmentId)
                .ToList();
        }
    }
    async Task SaveTask()
    {
        if (selectedTask != null)
        {
            _context.WorkTasks.Update(selectedTask);

            await _context.SaveChangesAsync();

            allTasks = await _context.WorkTasks.ToListAsync();

            tasks = allTasks
                .Where(t => t.Departments_idD == selectedDepartmentId)
                .ToList();

            StateHasChanged();
        }
    }
    async Task AddComment()
    {
        if (selectedTask == null
            || currentUser == null
            || string.IsNullOrWhiteSpace(newComment))
            return;

        var comment = new TaskComment
            {
                Comment = newComment,
                CommentTC = DateTime.Now,
                Tasks_idT = selectedTask.idT,
                Users_idU = currentUser.idU
            };

        _context.TaskComments.Add(comment);

        await _context.SaveChangesAsync();

        comments = await _context.TaskComments
            .Where(c => c.Tasks_idT == selectedTask.idT)
            .OrderBy(c => c.CommentTC)
            .ToListAsync();

        newComment = "";

        StateHasChanged();
    }
    async Task UploadFile(InputFileChangeEventArgs e)
    {
        if (selectedTask == null)
            return;

        var file = e.File;

        if (file == null)
            return;

        var uploadsFolder = Path.Combine(
            env.WebRootPath,
            "uploads"
        );

        if (!Directory.Exists(uploadsFolder))
        {
            Directory.CreateDirectory(uploadsFolder);
        }

        var uniqueFileName =
            $"{Guid.NewGuid()}_{file.Name}";

        var filePath = Path.Combine(
            uploadsFolder,
            uniqueFileName
        );

        await using var stream =
            new FileStream(filePath, FileMode.Create);

        await file.OpenReadStream(
            20 * 1024 * 1024)
            .CopyToAsync(stream);

        var taskFile = new TaskFile
            {
                FileName = file.Name,
                _FilePath = $"/uploads/{uniqueFileName}",
                UploadedAtTF = DateTime.Now,
                Tasks_idT = selectedTask.idT
            };

        _context.TaskFiles.Add(taskFile);

        await _context.SaveChangesAsync();

        taskFiles = await _context.TaskFiles
            .ToListAsync();

        StateHasChanged();
    }
    void OpenCreateTask()
    {
        newTask = new WorkTask();

        selectedFile = null;

        if (currentUser?.Role == "Manager")
        {
            selectedDepartmentForTask =
                currentUser.Departments_idD;
        }
        else
        {
            selectedDepartmentForTask = 0;
        }

        showCreateModal = true;
    }

    void CloseCreateTask()
    {
        showCreateModal = false;
    }
    async Task DeleteTask()
    {
        if (currentUser?.Role != "Admin")
            return;

        if (selectedTask == null)
            return;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"Удалить задачу '{selectedTask.Title}'?"
        );

        if (!confirmed)
            return;

        // удалить файлы задачи из БД
        var files = await _context.TaskFiles
            .Where(f => f.Tasks_idT == selectedTask.idT)
            .ToListAsync();

        _context.TaskFiles.RemoveRange(files);

        var taskComments = await _context.TaskComments
    .Where(c => c.Tasks_idT == selectedTask.idT)
    .ToListAsync();

        _context.TaskComments.RemoveRange(taskComments);

        // удалить саму задачу
        _context.WorkTasks.Remove(selectedTask);

        await _context.SaveChangesAsync();

        // обновить данные
        allTasks = await _context.WorkTasks.ToListAsync();

        taskFiles = await _context.TaskFiles.ToListAsync();

        tasks = allTasks
            .Where(t => t.Departments_idD == selectedDepartmentId)
            .ToList();

        selectedTask = null;

        StateHasChanged();
    }
    async Task DeleteOldCompletedTasks()
    {
        var completedStatus = await _context.WorkTaskStatuses
            .FirstOrDefaultAsync(s => s.NameTS == "Завершенные");

        if (completedStatus == null)
            return;

        var oldTasks = await _context.WorkTasks
            .Where(t =>
                t.TaskStatus_idTS == completedStatus.idTS &&
                t.UpdatedAtT != null &&
                t.UpdatedAtT <= DateTime.Now.AddDays(-20))
            .ToListAsync();

        if (!oldTasks.Any())
            return;

        foreach (var task in oldTasks)
        {
            var files = await _context.TaskFiles
                .Where(f => f.Tasks_idT == task.idT)
                .ToListAsync();

            _context.TaskFiles.RemoveRange(files);

            var comments = await _context.TaskComments
                .Where(c => c.Tasks_idT == task.idT)
                .ToListAsync();

            _context.TaskComments.RemoveRange(comments);
        }

        _context.WorkTasks.RemoveRange(oldTasks);

        await _context.SaveChangesAsync();
    }

    async Task Logout()
