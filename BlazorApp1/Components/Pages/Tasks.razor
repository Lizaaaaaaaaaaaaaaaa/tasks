    string GetDeadlineClass(WorkTask task)
    {
        // если срок не указан
        if (task.DueDate == null)
            return "";

        // если задача завершена — не красим
        var status = statuses.FirstOrDefault(s =>
            s.idTS == task.TaskStatus_idTS);

        if (status?.NameTS == "Завершенные")
            return "deadline-green";

        var daysLeft =
            (task.DueDate.Value.Date -
            DateTime.Now.Date).TotalDays;

        if (daysLeft < 0)
            return "deadline-overdue";

        if (daysLeft <= 2)
            return "deadline-red";

        if (daysLeft <= 5)
            return "deadline-yellow";

        return "deadline-green";
    }

