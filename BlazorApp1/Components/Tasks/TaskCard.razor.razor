.task-card {
    background: #3b3b3b;
    border-radius: 10px;
    padding: 12px;
    margin-bottom: 12px;
    cursor: pointer;
    transition: .2s;
}

.task-card:hover {
    background: #4a4a4a;
    transform: translateY(-2px);
}

.task-title {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 8px;
}

.task-desc {
    margin-bottom: 10px;
    color: #d0d0d0;
}

.task-footer {
    font-size: 13px;
    color: #c7c7c7;
}